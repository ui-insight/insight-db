# Superuser password for the shared postgres instance
POSTGRES_PASSWORD=change_me_to_a_secure_password

# Per-app bootstrap passwords live in init/01-create-databases.sql.
# Rotate them there before first startup or before replaying the SQL on an
# existing instance, then keep each application repo's env file in sync.
#
# Verified integration patterns (checked against affiliated repos on 2026-03-25):
#   OpenERA:            DATABASE_URL=postgresql+asyncpg://openera:<password>@insight-db:5432/openera[_dev]
#   UCM Daily Register: DATABASE_URL=postgresql+asyncpg://ucm:<password>@insight-db:5432/ucm_newsletter[_dev]
#   Audit Dashboard:    DATABASE_URL=postgresql+asyncpg://audit_user:<password>@insight-db:5432/audit_dashboard[_dev]
#   ProcessMapping:     INSIGHT_DB_NAME=processmapping[_dev], INSIGHT_DB_USER=processmapping, INSIGHT_DB_PASSWORD=<password>
#   ExecOrd:            DATABASE_URL=postgresql+asyncpg://execord:<password>@insight-db:5432/execord[_dev]
#   StratPlan:          supported when DATA_SOURCE=insight_db is enabled; provision stratplan[_dev] manually first
